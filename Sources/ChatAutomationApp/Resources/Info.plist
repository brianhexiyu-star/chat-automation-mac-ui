<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for AXUIElement window control -->
    <key>NSAccessibilityUsageDescription</key>
    <string>Chat Automator needs Accessibility access to move and control target application windows.</string>

    <!-- Required for CGWindowListCreateImage (config screenshot) -->
    <key>NSScreenCaptureUsageDescription</key>
    <string>Chat Automator takes a screenshot of the target app region so you can draw UI element boundaries for automation configuration.</string>

    <!-- Required for AppleScript fallback (window management) -->
    <key>NSAppleEventsUsageDescription</key>
    <string>Chat Automator uses Apple Events to manage windows of other applications.</string>

    <!-- Allow launching and communicating with Python subprocess -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>

    <!-- App metadata -->
    <key>CFBundleName</key>
    <string>ChatAutomator</string>
    <key>CFBundleDisplayName</key>
    <string>Chat Automator</string>
    <key>CFBundleIdentifier</key>
    <string>com.yourname.chat-automator</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>
    <key>LSUIElement</key>
    <false/>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
</dict>
</plist>
